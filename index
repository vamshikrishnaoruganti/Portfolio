<style>
:root {
  --bg: #0d0f12;
  --bg2: #13161a;
  --bg3: #1a1e24;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.13);
  --text: #e8eaed;
  --text2: #8a9ab0;
  --text3: #556070;
  --accent: #3b82f6;
  --accent2: #1d4ed8;
  --teal: #14b8a6;
  --coral: #f97316;
  --purple: #a78bfa;
  --green: #22c55e;
  --amber: #f59e0b;
  --font-head: 'Space Grotesk', sans-serif;
  --font-body: 'Inter', sans-serif;
  --r: 12px;
  --r-sm: 8px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { background: var(--bg); color: var(--text); font-family: var(--font-body); font-size: 15px; line-height: 1.6; }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(13,15,18,0.88); backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 2rem; height: 56px;
}
.nav-logo { font-family: var(--font-head); font-size: 16px; font-weight: 600; color: var(--text); letter-spacing: -0.3px; }
.nav-logo span { color: var(--accent); }
.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a { text-decoration: none; color: var(--text2); font-size: 13px; font-weight: 500; letter-spacing: 0.02em; transition: color 0.2s; }
.nav-links a:hover { color: var(--text); }
.nav-cta { background: var(--accent); color: #fff; font-size: 13px; font-weight: 500; padding: 7px 16px; border-radius: var(--r-sm); text-decoration: none; transition: background 0.2s; }
.nav-cta:hover { background: var(--accent2); }

/* HERO */
.hero {
  min-height: 100vh; display: flex; align-items: center;
  padding: 5rem 2rem 3rem; max-width: 1100px; margin: 0 auto;
  position: relative;
}
.hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; width: 100%; }
.hero-eyebrow { font-size: 12px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); font-weight: 500; margin-bottom: 1rem; }
.hero-name { font-family: var(--font-head); font-size: clamp(36px, 5vw, 60px); font-weight: 700; line-height: 1.05; letter-spacing: -1.5px; color: var(--text); }
.hero-name span { color: var(--accent); }
.hero-sub { font-size: 17px; color: var(--text2); margin-top: 1.25rem; line-height: 1.7; }
.hero-stats { display: flex; gap: 2rem; margin-top: 2rem; flex-wrap: wrap; }
.stat { }
.stat-num { font-family: var(--font-head); font-size: 28px; font-weight: 700; color: var(--text); }
.stat-label { font-size: 12px; color: var(--text3); margin-top: 1px; }
.hero-ctas { display: flex; gap: 12px; margin-top: 2.5rem; flex-wrap: wrap; }
.btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: var(--r-sm); font-size: 14px; font-weight: 500; text-decoration: none; transition: all 0.2s; }
.btn-primary { background: var(--accent); color: #fff; }
.btn-primary:hover { background: var(--accent2); }
.btn-outline { background: transparent; color: var(--text); border: 1px solid var(--border2); }
.btn-outline:hover { border-color: var(--accent); color: var(--accent); }
.hero-card {
  background: var(--bg2); border: 1px solid var(--border); border-radius: 20px;
  padding: 2rem; position: relative; overflow: hidden;
}
.hero-card::before {
  content: ''; position: absolute; top: -60px; right: -60px;
  width: 200px; height: 200px; border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,0.15) 0%, transparent 70%);
}
.avatar-circle {
  width: 80px; height: 80px; border-radius: 50%;
  background: linear-gradient(135deg, #1d4ed8, #7c3aed);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-head); font-size: 26px; font-weight: 700; color: #fff;
  margin-bottom: 1.25rem;
}
.hcard-name { font-family: var(--font-head); font-size: 20px; font-weight: 600; }
.hcard-role { font-size: 13px; color: var(--text2); margin-top: 3px; }
.hcard-info { margin-top: 1.25rem; display: flex; flex-direction: column; gap: 10px; }
.hcard-row { display: flex; align-items: center; gap: 10px; font-size: 13px; color: var(--text2); }
.hcard-row svg { width: 15px; height: 15px; opacity: 0.5; flex-shrink: 0; }
.chip-row { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 1.25rem; }
.chip { font-size: 11px; padding: 4px 10px; border-radius: 100px; font-weight: 500; }
.chip-blue { background: rgba(59,130,246,0.15); color: #93c5fd; }
.chip-teal { background: rgba(20,184,166,0.12); color: #5eead4; }
.chip-coral { background: rgba(249,115,22,0.12); color: #fdba74; }
.chip-purple { background: rgba(167,139,250,0.12); color: #c4b5fd; }

/* SECTIONS */
.section { padding: 5rem 2rem; max-width: 1100px; margin: 0 auto; }
.section-header { margin-bottom: 2.5rem; }
.section-eyebrow { font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); font-weight: 500; margin-bottom: 8px; }
.section-title { font-family: var(--font-head); font-size: 32px; font-weight: 700; letter-spacing: -0.5px; }
.section-title span { color: var(--text2); font-weight: 400; }

/* TIMELINE */
.tl { position: relative; padding-left: 28px; }
.tl::before { content: ''; position: absolute; left: 7px; top: 10px; bottom: 0; width: 1px; background: var(--border); }
.tl-item { position: relative; margin-bottom: 2.5rem; }
.tl-dot { position: absolute; left: -28px; top: 6px; width: 14px; height: 14px; border-radius: 50%; border: 2px solid var(--bg); }
.tl-inner { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r); padding: 1.25rem 1.5rem; }
.tl-role { font-family: var(--font-head); font-size: 17px; font-weight: 600; }
.tl-company { font-size: 14px; color: var(--accent); margin-top: 3px; }
.tl-period { font-size: 12px; color: var(--text3); margin-top: 3px; }
.tl-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; }
.tl-tag { font-size: 11px; padding: 3px 9px; border-radius: 100px; background: var(--bg3); color: var(--text2); border: 1px solid var(--border); }
.tl-bullets { margin-top: 12px; padding-left: 16px; display: flex; flex-direction: column; gap: 5px; }
.tl-bullets li { font-size: 13px; color: var(--text2); }

/* PROJECTS GRID */
.proj-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
.proj-card {
  background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r);
  overflow: hidden; transition: border-color 0.2s, transform 0.2s;
  display: flex; flex-direction: column;
}
.proj-card:hover { border-color: var(--border2); transform: translateY(-2px); }
.proj-img-box {
  width: 100%; height: 180px; background: var(--bg3);
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 8px; position: relative;
  border-bottom: 1px solid var(--border); overflow: hidden;
}
.proj-img-box img { width: 100%; height: 100%; object-fit: cover; }
.proj-img-box.empty svg { opacity: 0.18; width: 48px; height: 48px; }
.proj-img-placeholder { font-size: 12px; color: var(--text3); text-align: center; }
.img-link-btn {
  position: absolute; bottom: 8px; right: 8px;
  background: rgba(13,15,18,0.85); border: 1px solid var(--border2);
  border-radius: var(--r-sm); padding: 4px 10px; font-size: 11px; color: var(--text2);
  text-decoration: none; display: flex; align-items: center; gap: 5px;
  transition: color 0.2s, border-color 0.2s;
}
.img-link-btn:hover { color: var(--accent); border-color: var(--accent); }
.proj-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; }
.proj-phase { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 6px; }
.proj-name { font-family: var(--font-head); font-size: 16px; font-weight: 600; }
.proj-company { font-size: 12px; color: var(--text3); margin-top: 3px; }
.proj-desc { font-size: 13px; color: var(--text2); margin-top: 10px; line-height: 1.6; flex: 1; }
.proj-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 12px; }
.proj-tag { font-size: 10px; padding: 3px 8px; border-radius: 100px; background: var(--bg3); color: var(--text2); border: 1px solid var(--border); }
.proj-links { display: flex; gap: 8px; margin-top: 14px; flex-wrap: wrap; }
.proj-link {
  font-size: 12px; color: var(--text2); text-decoration: none;
  display: inline-flex; align-items: center; gap: 5px;
  border: 1px solid var(--border); border-radius: var(--r-sm);
  padding: 5px 10px; transition: all 0.2s; background: var(--bg3);
}
.proj-link:hover { color: var(--accent); border-color: var(--accent); }
.proj-link svg { width: 13px; height: 13px; }

/* SKILLS */
.skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
.skill-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r); padding: 1.25rem; }
.skill-card-label { font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
.skill-card-label svg { width: 16px; height: 16px; }
.skill-list { display: flex; flex-direction: column; gap: 5px; }
.skill-item { font-size: 13px; color: var(--text2); padding: 4px 0; border-bottom: 1px solid var(--border); }
.skill-item:last-child { border-bottom: none; }

/* DOCS */
.docs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 12px; }
.doc-card {
  background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r);
  padding: 1.25rem; display: flex; align-items: flex-start; gap: 14px;
  text-decoration: none; color: var(--text); transition: border-color 0.2s;
}
.doc-card:hover { border-color: var(--accent); }
.doc-icon { width: 40px; height: 40px; border-radius: var(--r-sm); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.doc-icon svg { width: 20px; height: 20px; }
.doc-title { font-size: 14px; font-weight: 500; }
.doc-desc { font-size: 12px; color: var(--text3); margin-top: 3px; }
.doc-tag { font-size: 11px; color: var(--accent); margin-top: 8px; display: flex; align-items: center; gap: 4px; }
.doc-tag svg { width: 12px; height: 12px; }

/* CONTACT */
.contact-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
.contact-info { display: flex; flex-direction: column; gap: 14px; }
.contact-row { display: flex; align-items: center; gap: 12px; font-size: 14px; color: var(--text2); }
.contact-row svg { width: 16px; height: 16px; color: var(--accent); flex-shrink: 0; }
.contact-row a { color: var(--accent); text-decoration: none; }
.contact-row a:hover { text-decoration: underline; }
.contact-message { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--r); padding: 1.5rem; }
.contact-message p { font-size: 14px; color: var(--text2); line-height: 1.75; }

/* FOOTER */
footer { border-top: 1px solid var(--border); padding: 2rem; text-align: center; font-size: 12px; color: var(--text3); }

/* DIVIDERS */
.full-divider { height: 1px; background: var(--border); }

/* COLOR ACCENTS */
.dot-blue { background: var(--accent); }
.dot-green { background: var(--green); }
.dot-amber { background: var(--amber); }
.dot-coral { background: var(--coral); }
.dot-gray { background: var(--text3); }
.dot-purple { background: var(--purple); }

/* RESPONSIVE */
@media (max-width: 768px) {
  .hero-grid { grid-template-columns: 1fr; }
  .contact-grid { grid-template-columns: 1fr; }
  nav .nav-links { display: none; }
}
</style>
